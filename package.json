{
  "name": "file-exchange",
  "version": "0.1.0",
  "private": true,
  "productName": "File Exchange",
  "description": "End-to-end encrypted file sharing — web edition",
  "author": { "name": "Liaskos", "email": "noreply@example.com" },
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": "20.x" },
  "scripts": {
